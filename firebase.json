{
  "flutter": {
    "platforms": {
      "dart": {
        "lib/firebase_options.dart": {
          "projectId": "rajadhanigamesl",
          "configurations": {
            "android": "1:999174467302:android:55354416d69f7cef7f1527",
            "web": "1:999174467302:web:7d98924a35f738657f1527"
          }
        }
      },
      "android": {
        "default": {
          "projectId": "rajadhanigamesl",
          "appId": "1:999174467302:android:55354416d69f7cef7f1527",
          "fileOutput": "android/app/google-services.json"
        }
      }
    }
  },
  "hosting": {
    "public": "build/web",
    "ignore": [
      "firebase.json",
      "**/.*",
      "**/node_modules/**"
    ],
    "rewrites": [
      {
        "source": "**",
        "destination": "/index.html"
      }
    ],
    "headers": [
      {
        "source": "/@(index.html|flutter_service_worker.js)",
        "headers": [
          {
            "key": "Cache-Control",
            "value": "no-cache, no-store, must-revalidate"
          }
        ]
      }
    ]
  },
  "firestore": {
    "rules": "firestore.rules"
  }
}